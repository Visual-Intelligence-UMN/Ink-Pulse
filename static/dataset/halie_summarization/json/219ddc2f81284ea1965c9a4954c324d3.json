      "pos": 0,
      "progress": 0.0
    },
    {
      "name": "text-insert",
      "text": "Ian James Whyte from Peebles has been named by police as the driver of the black Vauxhall Vivaro van that came off the road on the B6362 Lauder to Stow Road in Dundee.",
      "eventSource": "api",
      "event_time": "2022-09-15 08:22:22",
      "pos": 0,
      "progress": 0.6374
    },
    {
      "name": "text-delete",
      "text": "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
      "count": 167,
      "eventSource": "api",
      "event_time": "2022-09-15 08:23:13",
      "pos": 0,
      "progress": 0.0
    },
    {
      "name": "text-insert",
      "text": "The award is chosen by a race management team, which includes clerk of the course Gary Thompson and rider liaison officer Richard Quayle.",
      "eventSource": "api",
      "event_time": "2022-09-15 08:23:13",
      "pos": 0,
      "progress": 0.5229
    },
    {
      "name": "text-delete",
      "text": "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
      "count": 137,
      "eventSource": "api",
      "event_time": "2022-09-15 08:24:31",
      "pos": 0,
      "progress": 0.0
    },
    {
      "name": "text-insert",
      "text": "The 27-year-old joined the Saints in summer 2014 from FC Twente and has since scored 13 goals for them.",
      "eventSource": "api",
      "event_time": "2022-09-15 08:24:31",
      "pos": 0,
      "progress": 0.3931
    },
    {
      "name": "text-delete",
      "text": "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
      "count": 103,
      "eventSource": "api",
