    {
      "name": "text-insert",
      "text": "The man was discovered at about 07:00 at the Morrisons store on Forfar Road, Dundee.",
      "eventSource": "api",
      "event_time": "2022-09-15 08:15:06",
      "pos": 0,
      "progress": 0.3206
    },
    {
      "name": "text-insert",
      "text": " ",
      "eventSource": "user",
      "event_time": "2022-09-15 08:19:27",
      "pos": 0,
      "progress": 0.3244
    },
    {
      "name": "text-insert",
      "text": "He has the letters DFC tattooed on his right ankle, a leaf on his right upper arm and a tattoo of a ship on his left forearm. Anyone with information is urged to contact police.",
      "eventSource": "user",
      "event_time": "2022-09-15 08:19:28",
      "pos": 0,
      "progress": 1.0
    },
    {
      "name": "text-delete",
      "text": "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
      "count": 262,
      "eventSource": "api",
      "event_time": "2022-09-15 08:19:37",
      "pos": 0,
      "progress": 0.0
    },
    {
      "name": "text-insert",
      "text": "\"Bup stop\" was painted in large yellow lettering after a worn road surface was repaired.",
      "eventSource": "api",
      "event_time": "2022-09-15 08:19:37",
      "pos": 0,
      "progress": 0.3359
    },
    {
      "name": "text-insert",
      "text": " ",
      "eventSource": "user",
      "event_time": "2022-09-15 08:22:09",
      "pos": 0,
      "progress": 0.3397
    },
    {
      "name": "text-insert",
      "text": "as part of work expected to last up to four weeks in the Old Market area of the city centre.",
      "eventSource": "user",
      "event_time": "2022-09-15 08:22:09",
      "pos": 0,
      "progress": 0.6908
    },
    {
      "name": "text-delete",
      "text": "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
      "count": 34,
      "eventSource": "user",
