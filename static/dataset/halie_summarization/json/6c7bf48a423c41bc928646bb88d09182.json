      "pos": 0,
      "progress": 0.0
    },
    {
      "name": "text-insert",
      "text": "He has scored four goals in eight games since his move to the Lilywhites.",
      "eventSource": "api",
      "event_time": "2022-09-15 09:17:24",
      "pos": 0,
      "progress": 0.2694
    },
    {
      "name": "text-insert",
      "text": "Ex-Blackpool playr Barkhuizen",
      "eventSource": "user",
      "event_time": "2022-09-15 09:26:50",
      "pos": 0,
      "progress": 0.3764
    },
    {
      "name": "text-delete",
