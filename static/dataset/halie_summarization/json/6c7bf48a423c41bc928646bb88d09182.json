    {
      "name": "text-insert",
      "text": "Buckner, the CEO of British Triathlon, will succeed David Sparkes when he retires in June after 23 years with British Swimming.",
      "eventSource": "api",
      "event_time": "2022-09-15 09:15:13",
      "pos": 0,
      "progress": 0.4686
    },
    {
      "name": "text-delete",
