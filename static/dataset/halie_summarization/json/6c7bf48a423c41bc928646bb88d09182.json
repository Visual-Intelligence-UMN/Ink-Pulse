      "pos": 0,
      "progress": 0.0
    },
    {
      "name": "text-insert",
      "text": "Wasps finished top of this season's Premiership and defeated Leicester 21-20 on Saturday to set up this weekend's decider against Exeter.",
      "eventSource": "api",
      "event_time": "2022-09-15 09:27:18",
      "pos": 0,
      "progress": 0.5055
    },
    {
