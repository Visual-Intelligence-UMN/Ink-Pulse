      "pos": 0,
      "progress": 0.0
    },
    {
      "name": "text-insert",
      "text": "Portugal captain Ronaldo has been continuously linked with former club Manchester United, who sold him to Real in 2008, and Paris St-Germain.",
      "eventSource": "api",
      "event_time": "2022-09-15 09:27:46",
      "pos": 0,
      "progress": 0.5203
    },
    {
      "name": "text-insert",
