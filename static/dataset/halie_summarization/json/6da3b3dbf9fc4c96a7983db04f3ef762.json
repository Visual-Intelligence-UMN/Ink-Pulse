    {
      "name": "text-insert",
      "text": "He will now undergo surgery on his knee before beginning a rehabilitation programme.",
      "eventSource": "user",
      "event_time": "2022-09-15 10:00:31",
      "pos": 0,
      "progress": 0.6233
    },
    {
      "name": "text-delete",
      "text": "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
      "count": 225,
      "eventSource": "api",
      "event_time": "2022-09-15 10:00:45",
      "pos": 0,
      "progress": 0.0
    },
    {
      "name": "text-insert",
      "text": "A man was killed in an altercation in the early hours of the morning in Waterford, Ireland.",
      "eventSource": "api",
      "event_time": "2022-09-15 10:00:45",
      "pos": 0,
      "progress": 0.2521
    },
    {
      "name": "text-delete",
      "text": "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
      "count": 91,
      "eventSource": "api",
      "event_time": "2022-09-15 10:02:02",
      "pos": 0,
      "progress": 0.0
    },
    {
      "name": "text-insert",
      "text": "A man was arrested and charged after an elderly woman was hit with a crowbar during a robbery at a church in Portadown, Northern Ireland.",
      "eventSource": "api",
      "event_time": "2022-09-15 10:02:02",
      "pos": 0,
      "progress": 0.3795
    },
    {
      "name": "text-delete",
      "text": "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
      "count": 137,
      "eventSource": "api",
      "event_time": "2022-09-15 10:03:20",
      "pos": 0,
      "progress": 0.0
    },
    {
      "name": "text-insert",
      "text": "Schneidermann, a recent graduate, moved to the Welsh town to photograph those growing up in an area with huge economic and social pressures.",
      "eventSource": "api",
      "event_time": "2022-09-15 10:03:20",
      "pos": 0,
      "progress": 0.3878
    },
    {
      "name": "text-delete",
      "text": "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
      "count": 140,
      "eventSource": "api",
      "event_time": "2022-09-15 10:04:23",
      "pos": 0,
      "progress": 0.0
    },
    {
      "name": "text-insert",
      "text": "Mane is available again after Senegal lost 5-4 on penalties to Cameroon in the quarter-finals.",
      "eventSource": "api",
      "event_time": "2022-09-15 10:04:23",
      "pos": 0,
      "progress": 0.2604
    },
    {
      "name": "text-insert",
      "text": " ",
      "eventSource": "user",
      "event_time": "2022-09-15 10:05:01",
      "pos": 0,
      "progress": 0.2632
    },
    {
      "name": "text-insert",
      "text": "They were knocked out of the EFL Cup by Mane's former club on Wednesday, then eliminated from the FA Cup by Championship side Wolves on Saturday.",
      "eventSource": "user",
      "event_time": "2022-09-15 10:05:01",
      "pos": 0,
      "progress": 0.6648
    },
    {
      "name": "text-delete",
      "text": "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
      "count": 240,
      "eventSource": "api",
      "event_time": "2022-09-15 10:05:06",
      "pos": 0,
      "progress": 0.0
    },
    {
      "name": "text-insert",
      "text": "The 2014-15 report from Public Health Wales showed 78% of women in the target age of 25 to 64 had been tested.",
      "eventSource": "api",
      "event_time": "2022-09-15 10:05:06",
      "pos": 0,
      "progress": 0.3047
    },
    {
      "name": "text-delete",
      "text": "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
      "count": 110,
      "eventSource": "api",
      "event_time": "2022-09-15 10:05:54",
      "pos": 0,
      "progress": 0.0
    },
    {
      "name": "text-insert",
      "text": "Romero, 30, joined United on a free transfer in 2015 after leaving Italian side Sampdoria.",
      "eventSource": "api",
      "event_time": "2022-09-15 10:05:54",
      "pos": 0,
      "progress": 0.2493
    },
    {
      "name": "text-delete",
